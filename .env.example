# ═══════════════════════════════════════════════════════════════
# Sim Racing Telemetry — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this to .env and fill in your values

# ── Deployment Mode ──
# Set to "aws" to route telemetry to AWS cloud services
# Set to "local" to use local Kafka + Parquet (default)
DEPLOYMENT_MODE=local

# Kafka (local mode)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# PostgreSQL (local mode)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=telemetry
POSTGRES_USER=telemetry
POSTGRES_PASSWORD=telemetry_pass

# ── AWS Configuration (aws mode) ──
AWS_REGION=us-east-1
S3_BUCKET=sim-telemetry-lake
S3_RAW_PREFIX=raw/
S3_PROCESSED_PREFIX=processed/
FIREHOSE_STREAM_NAME=telemetry-firehose
ATHENA_DATABASE=sim_telemetry
# ATHENA_RESULTS_BUCKET=s3://sim-telemetry-lake/athena-results/

# Claude API (Week 6)
# ANTHROPIC_API_KEY=your_key_here

